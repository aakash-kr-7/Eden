# =============================================================================
# .env.example — Template for Eden Backend Configuration
# =============================================================================
#
# INSTRUCTIONS:
#   1. Copy this file to a new file named '.env' in the root or backend directory.
#   2. Replace the placeholder values below with your actual credentials.
#   3. Never commit your active '.env' file containing secrets to version control.
#

# ── Required Settings ────────────────────────────────────────────────────────
# Path to the SQLite DB file. Make sure the containing folder is writeable.
# Example: backend/db/partner.db (or c:\Users\aakash09\Desktop\Eden\backend\db\partner.db)
DATABASE_URL=backend/db/partner.db

# Absolute path to the Firebase Service Account JSON credentials file.
# Used for verifying Firebase JWT tokens on auth endpoints.
FIREBASE_CREDENTIALS_PATH=/absolute/path/to/firebase-credentials.json

# Groq API Key. Get one free from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Groq Model ID to route primary conversation tasks through.
# Default: llama-3.1-70b-versatile
GROQ_MODEL=llama-3.1-70b-versatile

# Max number of previous messaging turns to maintain in active LLM context.
# Default: 20
MAX_CONTEXT_MESSAGES=20

# Toggle to enable/disable periodic semantic memory extraction.
# Default: True
MEMORY_EXTRACTION_ENABLED=True

# Toggle to enable/disable proactive outreach/messaging from the partner.
# Default: True
PROACTIVE_ENGINE_ENABLED=True

# Maximum number of message segments sent in a single text burst.
# Default: 4
BURST_MAX_MESSAGES=4

# Minimum simulated typing delay between consecutive bursts (in seconds).
# Default: 3
BURST_MIN_DELAY_SECONDS=3

# Maximum simulated typing delay between consecutive bursts (in seconds).
# Default: 12
BURST_MAX_DELAY_SECONDS=12

# Time tick frequency (in seconds) for simulating partner life events.
# Default: 300
LIFE_SIMULATOR_TICK_SECONDS=300

# Logging level of the application ('DEBUG', 'INFO', 'WARNING', 'ERROR').
# Default: INFO
LOG_LEVEL=INFO

# Environment of the application ('development' or 'production').
# Default: development
ENVIRONMENT=development

# JSON array/comma-separated origins permitted to access resources via CORS.
# Default: ["*"]
ALLOWED_ORIGINS=["*"]

# Secret token used for bypassing client security in admin/debugging endpoints.
# Default: admin_secret
ADMIN_DEBUG_TOKEN=admin_secret

# Ops console secret key used to guard operational endpoints via the X-Ops-Key header.
# Default: ops_secret_default_key
OPS_SECRET_KEY=ops_secret_default_key

# ── Optional/Existing Settings (with defaults) ──────────────────────────────
# Directory holding partner archetype definitions.
# Default: backend/personality/archetypes
ARCHETYPES_DIR=backend/personality/archetypes

# Default partner archetype to assign to users during matching fallback.
# Default: the_anchor
DEFAULT_PARTNER=the_anchor

# Controls prompt engineering response creativity. 0.0 = deterministic, 1.0 = highly creative.
# Default: 0.82
LLM_TEMPERATURE=0.82

# Max output tokens generated by model in a single reply segment.
# Default: 300
LLM_MAX_TOKENS=300

# Primary fallback model in case of rate limits or provider downtime.
# Default: llama-3.1-8b-instant
LLM_FALLBACK_MODEL=llama-3.1-8b-instant

# Custom API endpoint for Groq or compatible OpenAI-like providers.
# Default: https://api.groq.com/openai/v1
GROQ_BASE_URL=https://api.groq.com/openai/v1

# The host address the uvicorn server should bind to.
# Default: 0.0.0.0
APP_HOST=0.0.0.0

# The port the uvicorn server listens on.
# Default: 8000
APP_PORT=8000

# Firebase Project ID (found in Firebase console settings).
# Default: eden-platform-project
FIREBASE_PROJECT_ID=eden-platform-project

# Hour of the day representing start of quiet hours (when notifications are suppressed).
# Default: 23 (11 PM)
PROACTIVE_DEFAULT_QUIET_HOURS_START=23

# Hour of the day representing end of quiet hours.
# Default: 8 (8 AM)
PROACTIVE_DEFAULT_QUIET_HOURS_END=8

# Maximum number of memories retrieved per query for LLM context context assembly.
# Default: 6
MEMORY_RETRIEVAL_COUNT=6

# Score threshold (0.0 to 1.0) above which retrieved memories are considered relevant.
# Default: 0.35
MEMORY_SIMILARITY_THRESHOLD=0.35

# Trigger semantic retrieval memory extraction after every N messaging turns.
# Default: 1
MEMORY_EXTRACTION_EVERY_N_TURNS=1
