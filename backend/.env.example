# Eden Environment Configuration

# Current running environment (development, production, staging)
ENVIRONMENT=development

# Server logger logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Host to bind the FastAPI app server
APP_HOST=0.0.0.0

# Port to bind the FastAPI app server
APP_PORT=8001

# SQLite Database connection URL
DATABASE_URL=./data/eden.db

# API Key for Groq cloud services
GROQ_API_KEY=gsk_your_groq_api_key_goes_here

# Groq Chat LLM model name used for conversations
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Groq Fast LLM model name used for background consolidation/dream jobs
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Temperature parameter for LLM response generation (ranges 0.0 - 1.0)
LLM_TEMPERATURE=0.85

# Max tokens constraint for LLM text responses
LLM_MAX_TOKENS=400

# Maximum number of chat history messages retrieved in session context
MAX_CONTEXT_MESSAGES=10

# Firebase project identifier
FIREBASE_PROJECT_ID=eden-app-project-id

# Local relative or absolute path to the Firebase Service Account JSON credentials file
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Optional: Base64 encoded string of Firebase Service Account JSON credentials (used in Production)
FIREBASE_CREDENTIALS_B64=

# Whether the background memory extraction engine is enabled (true/false)
MEMORY_EXTRACTION_ENABLED=true

# Cosine similarity threshold for vec memory retrieval (0.0 to 1.0)
MEMORY_SIMILARITY_THRESHOLD=0.4

# Maximum number of memories retrieved and injected in prompt context
MAX_MEMORIES_IN_CONTEXT=5

# Whether the proactive outreach evaluation engine is enabled (true/false)
PROACTIVE_ENGINE_ENABLED=true

# Wait interval in seconds between Life Simulator evaluation ticks
LIFE_SIMULATOR_TICK_SECONDS=300

# Maximum number of message segments returned in a single chat burst
BURST_MAX_MESSAGES=4

# Minimum delay in seconds before sending consecutive message bursts
BURST_MIN_DELAY_SECONDS=3

# Maximum delay in seconds before sending consecutive message bursts
BURST_MAX_DELAY_SECONDS=12

# Secret key required to access administrative backend operation endpoints (/api/ops)
OPS_SECRET_KEY=dev-only-change-in-production
