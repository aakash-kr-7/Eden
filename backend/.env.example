# =============================================================================
# .env.example — Template for Eden Backend Configuration
# =============================================================================
#
# INSTRUCTIONS:
#   1. Copy this file to a new file named '.env' in this directory.
#   2. Replace the placeholder values below with your actual service credentials.
#   3. Never commit your active '.env' file containing secrets to version control.
#

# ── General Settings ────────────────────────────────────────────────────────
# Environment of the application ('development' or 'production'). Defaults to 'development'.
ENVIRONMENT=development

# Logging level of the application ('DEBUG', 'INFO', 'WARNING', 'ERROR', 'CRITICAL').
# Default: INFO
LOG_LEVEL=INFO

# ── API / Network Settings ──────────────────────────────────────────────────
# The host address uvicorn server should bind to. Default: 0.0.0.0
APP_HOST=0.0.0.0

# The port the API server listens on. Default: 8000
APP_PORT=8000

# Comma-separated list of origins permitted to access resources via CORS.
# Use ["*"] to allow all domains or list them explicitly: http://localhost:3000,http://localhost:8080
ALLOWED_ORIGINS=*

# ── SQLite Database ─────────────────────────────────────────────────────────
# Path to the SQLite DB file. Make sure the containing folder is writeable.
# Default: backend/db/companion.db
DATABASE_URL=backend/db/companion.db

# ── Chroma Vector Database ──────────────────────────────────────────────────
# Path to where semantic episodic memory embeddings are saved on disk.
# Default: backend/chroma_db
CHROMA_DB_PATH=backend/chroma_db

# ── LLM (Groq / Anthropic Integration) ──────────────────────────────────────
# Groq API Key. Get one free from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Groq Model ID to route primary conversation tasks through.
# Default: llama-3.1-70b-versatile
GROQ_MODEL=llama-3.1-70b-versatile

# Primary fallback model in case of rate limits or provider downtime.
# Default: llama-3.1-8b-instant
LLM_FALLBACK_MODEL=llama-3.1-8b-instant

# Controls prompt engineering response creativity. 0.0 = completely deterministic, 1.0 = highly creative.
# Default: 0.82
LLM_TEMPERATURE=0.82

# Max output tokens generated by model in a single reply segment.
# Default: 300
LLM_MAX_TOKENS=300

# Max number of previous messaging turns to maintain in active LLM context.
# Default: 20
MAX_CONTEXT_MESSAGES=20

# ── Memory Retrieval and Extraction ─────────────────────────────────────────
# Toggle to enable/disable periodic semantic fact extraction logic.
# Default: True
MEMORY_EXTRACTION_ENABLED=True

# Trigger semantic retrieval memory extraction after every N messaging turns.
# Default: 1
MEMORY_EXTRACTION_EVERY_N_TURNS=1

# Maximum number of memories retrieved per query from the Chroma DB.
# Default: 6
MEMORY_RETRIEVAL_COUNT=6

# Score threshold (0.0 to 1.0) above which retrieved memories are considered relevant.
# Default: 0.35
MEMORY_SIMILARITY_THRESHOLD=0.35

# ── Proactive Engine & Notifications ────────────────────────────────────────
# Toggle to enable/disable companion proactive outbound event loops.
# Default: True
PROACTIVE_ENGINE_ENABLED=True

# Firebase Cloud Messaging (FCM) legacy server key for dispatching push notifications.
FCM_SERVER_KEY=your_fcm_server_key_here

# ── Delay / Pacing Burst Simulator ─────────────────────────────────────────
# Maximum number of message segments sent in a single text burst.
# Default: 4
BURST_MAX_MESSAGES=4

# Minimum simulated typing delay between consecutive bursts (in seconds).
# Default: 3
BURST_MIN_DELAY_SECONDS=3

# Maximum simulated typing delay between consecutive bursts (in seconds).
# Default: 12
BURST_MAX_DELAY_SECONDS=12

# ── Background Scheduler & Simulator ───────────────────────────────────────
# Time tick frequency (in seconds) for simulating character routine events.
# Default: 300
LIFE_SIMULATOR_TICK_SECONDS=300

# ── Firebase Authentication Settings ───────────────────────────────────────
# Firebase Project ID (found in Firebase console settings).
# Default: sol-mvp-4f7c1
FIREBASE_PROJECT_ID=sol-mvp-4f7c1

# Absolute path to the service account credential JSON file.
# Used for verifying Firebase JWT tokens on startup.
FIREBASE_CREDENTIALS_PATH=/absolute/path/to/firebase-service-account.json
